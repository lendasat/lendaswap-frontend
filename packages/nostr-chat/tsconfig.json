{
  "compilerOptions": {
    "jsx": "react-jsx",
    "allowJs": false,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "#/components/*": ["../shadcn/src/components/*"],
      "#/lib/utils": ["../shadcn/src/lib/utils.ts"],
      "#/lib/*": ["../shadcn/src/lib/*"],
      "#/components/ui/*": ["../shadcn/src/components/ui/*"],
      "#/hooks/*": ["../shadcn/src/hooks/*"]
    }
  },
  "extends": "../../tsconfig.base.json",
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
